POSTGRES_DB=vhv_monitor
POSTGRES_USER=vhv_monitor
# For local development only. In production prefer Docker secrets and do not commit .env.
POSTGRES_PASSWORD=change-me
DATABASE_HOST=localhost
DATABASE_PORT=5432
API_BIND=0.0.0.0
PORT=4000
WEB_BIND=127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=/api/v1
API_INTERNAL_URL=http://api:4000
API_PUBLIC_ORIGIN=https://monitor.example.local
LOG_LEVEL=info
WORKER_CONCURRENCY=1
WORKER_COOLDOWN_MS=3000
WORKER_POLL_INTERVAL_MS=5000
DEFAULT_CHECK_TIMEOUT_MS=30000
# SSRF guard for provider imports/connectivity tests. Keep false in production.
# Only enable for trusted, isolated internal providers (see docs/security.md).
ALLOW_PRIVATE_PROVIDER_HOSTS=false
TELEGRAM_ALERTS_ENABLED=false
# Required in production: 32-byte AES key encoded as base64 or 64-character hex.
# Prefer MASTER_KEY_FILE via Docker secrets instead of MASTER_KEY in shell history.
MASTER_KEY=
# Optional Telegram incident notifications. Leave disabled unless both secret values are provided securely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_COOLDOWN_MS=1800000
