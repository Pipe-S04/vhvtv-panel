{
  "name": "vhvtv-panel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "NEXT_TELEMETRY_DISABLED=1 pnpm -r --if-present build",
    "dev": "pnpm -r --parallel --if-present dev",
    "test": "pnpm -r --if-present test",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.15.32",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "zod": "^3.25.64"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.15"
    }
  }
}
