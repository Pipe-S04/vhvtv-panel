{
  "name": "@vhvtv/monitoring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vhvtv/database": "workspace:*",
    "@vhvtv/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./importers": {
      "types": "./dist/importers/index.d.ts",
      "default": "./dist/importers/index.js"
    }
  }
